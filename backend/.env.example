# Backend Environment Variables
# Copy this file to .env and fill in your values for local development

# MongoDB Connection
# Get from: https://cloud.mongodb.com → Database → Connect → Connection String
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net

# Database name
DB_NAME=vyaparseth

# Secret key for JWT (minimum 32 characters for production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-minimum-32-characters-long

# Groq API Key for AI features
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# CORS Origins (JSON array)
# Update with your frontend URL(s)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Environment (development or production)
ENVIRONMENT=development
